{
    "process": {
        "cpu_affinity": "auto"
    },
    "performance": {
        "enable_dco": true,
        "socket_recv_buffer": 4194304,
        "socket_send_buffer": 4194304,
        "batch_size": 4096,
        "process_quanta": 128,
        "stats_interval_seconds": 120
    },
    "logging": {
        "verbosity": "info",
        "subsystems": {
            "dataio": "info",
            "control": "debug"
        }
    },
    "server": {
        "host": "0.0.0.0",
        "port": 1194,
        "proto": "udp",
        "dev": "tun",
        "dev_node": "/dev/net/tun",
        "keepalive": [
            20,
            120
        ],
        "cipher": "AES-256-GCM",
        "auth": "SHA256",
        "tls_cipher": "TLS-DHE-RSA-WITH-AES-256-GCM-SHA384",
        "keysize": 256,
        "ca_cert": "test_data/certs/ca.crt",
        "tls_crypt_key": "test_data/certs/tls-crypt.key",
        "cert": "test_data/certs/server.crt",
        "key": "test_data/certs/server.key",
        "dh_params": "test_data/certs/dh2048.pem",
        "network": "10.8.0.0/24",
        "bridge_ip": "10.8.0.1",
        "client_dns": [
            "8.8.8.8",
            "8.8.4.4"
        ],
        "routes": [
            "192.168.50.0/24"
        ],
        "push_routes": true,
        "tun_mtu": 1400,
        "client_cert_required": true,
        "username_password": false,
        "max_clients": 100,
        "ping_timer_remote": 60,
        "renegotiate_seconds": 3600
    },
    "clients": [
        {
            "server_host": "10.0.0.2",
            "server_port": 1194,
            "protocol": "udp",
            "cipher": "AES-256-GCM",
            "auth": "SHA256",
            "ca_cert": "test_data/certs/ca.crt",
            "tls_crypt_key": "test_data/certs/tls-crypt.key",
            "cert": "test_data/certs/client.crt",
            "key": "test_data/certs/client.key",
            "keepalive_interval": 10,
            "keepalive_timeout": 60,
            "reconnect_delay_seconds": 5,
            "max_reconnect_attempts": 10
        }
    ]
}