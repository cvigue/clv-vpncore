{
    "server": {
        "host": "0.0.0.0",
        "port": 1194,
        "proto": "udp",
        "dev": "tun",
        "dev_node": "/dev/net/tun",
        "keepalive": [
            20,
            120
        ]
    },
    "crypto": {
        "ca_cert": "test_data/certs/ca.crt",
        "server_cert": "test_data/certs/server.crt",
        "server_key": "test_data/certs/server.key",
        "dh_params": "test_data/certs/dh2048.pem",
        "cipher": "AES-256-GCM",
        "auth": "SHA256",
        "tls_cipher": "TLS-DHE-RSA-WITH-AES-256-GCM-SHA384",
        "keysize": 256,
        "tls_crypt_key": "test_data/certs/tls-crypt.key"
    },
    "network": {
        "server_network": "10.8.0.0/24",
        "server_network_v6": "fd00::/112",
        "server_bridge": "10.8.0.1",
        "client_dns": [
            "8.8.8.8",
            "8.8.4.4"
        ],
        "routes": [
            "192.168.50.0/24"
        ],
        "routes_v6": [
            "fd01::/64"
        ],
        "push_routes": true,
        "tun_mtu": 1400,
        "tun_txqueuelen": 4096
    },
    "auth": {
        "client_cert_required": true,
        "username_password": false,
        "crl_verify": true,
        "crl_file": ""
    },
    "performance": {
        "max_clients": 100,
        "enable_dco": true,
        "ping_timer_remote": 60,
        "renegotiate_seconds": 3600,
        "stats_interval_seconds": 30,
        "socket_recv_buffer": 4194304,
        "socket_send_buffer": 4194304,
        "batch_size": 4096,
        "process_quanta": 128,
        "lame_duck_seconds": 0,
        "cpu_affinity": {
            "mode": "auto",
            "probe_interval": 20,
            "probe_duration": 1,
            "baseline_windows": 5,
            "ema_alpha": 0.3,
            "throughput_threshold": 0.75,
            "window_seconds": 15.0
        }
    },
    "logging": {
        "verbosity": "info",
        "subsystems": {
            "dataio": "info",
            "control": "debug"
        }
    }
}