client
dev tun
proto udp
remote 192.168.50.2 1194
resolv-retry infinite
nobind
persist-key
persist-tun
sndbuf 4194304
rcvbuf 4194304
cipher AES-256-GCM
data-ciphers AES-256-GCM:AES-128-GCM
auth none
verb 3
ca test_data/certs/ca.crt
cert test_data/certs/client.crt
key test_data/certs/client.key
tls-crypt test_data/certs/tls-crypt.key
