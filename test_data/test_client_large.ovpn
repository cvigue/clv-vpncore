##############################################
# OpenVPN Client Configuration for Large Cert Testing
# Tests 4096-bit RSA certificate fragmentation
##############################################

client
dev tun
proto udp

# Connect to server (use actual IP for remote testing, 127.0.0.1 for local)
remote 127.0.0.1 1194

# Keep trying indefinitely on resolving errors
resolv-retry infinite

# Don't bind to local address and port
nobind

# Enable verbose logging for debugging
verb 6

# Preserve keys across restarts
persist-key
persist-tun

# Cryptographic settings
cipher AES-256-GCM
auth SHA256

# Keepalive
keepalive 10 120

