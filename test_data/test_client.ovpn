##############################################
# OpenVPN Client Configuration for CLVLib Test Server
# Auto-generated for tls-crypt testing
##############################################

client
dev tun
proto udp

# Connect to server
remote 127.0.0.1 1194

# Keep trying indefinitely on resolving errors
resolv-retry infinite

# Don't bind to local address and port
nobind

# Enable verbose logging for debugging
verb 3

# Preserve keys across restarts
persist-key
persist-tun

# DCO (Data Channel Offload) - testing with it enabled
disable-dco

# Cryptographic settings
cipher AES-256-GCM
auth SHA256

# Logging verbosity (3 = normal, 6+ = debug)
verb 3

# Keepalive
keepalive 10 120

